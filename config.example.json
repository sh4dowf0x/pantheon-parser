{
  "capture": {
    "mode": "autoCombatLog",
    "window": {
      "processName": "Pantheon",
      "processId": null,
      "titleContains": "Pantheon",
      "useClientArea": true,
      "useForeground": true
    },
    "windowFraction": {
      "x": 0.72,
      "y": 0.80,
      "width": 0.27,
      "height": 0.18
    },
    "fraction": {
      "x": 0.58,
      "y": 0.70,
      "width": 0.40,
      "height": 0.23
    },
    "absolute": {
      "x": 2220,
      "y": 1510,
      "width": 1530,
      "height": 500
    },
    "windowAbsolute": {
      "x": 1485,
      "y": 930,
      "width": 550,
      "height": 200
    },
    "autoCombatLog": {
      "x": 0.55,
      "y": 0.68,
      "width": 0.45,
      "height": 0.32,
      "searchX": 0.55,
      "searchY": 0.55,
      "searchWidth": 0.45,
      "searchHeight": 0.45,
      "minWidth": 0.2,
      "maxWidth": 0.34,
      "minHeight": 0.1,
      "maxHeight": 0.24,
      "darkCutoff": 55,
      "padding": 12,
      "lockRegion": true,
      "refineToDarkBounds": true,
      "panelBackgroundColor": "#000000",
      "panelBackgroundTolerance": 2,
      "panelMinRowRatio": 0.15,
      "panelMinColRatio": 0.1,
      "panelMinRunHeight": 10,
      "panelMinRunWidth": 10,
      "edgeDarkCutoff": 28,
      "edgeMinDarkRatio": 0.5,
      "edgeMinRowDarkRatio": 0.84,
      "edgeMinColDarkRatio": 0.5,
      "edgeMinWidth": 0.65,
      "edgeMinHeight": 0.45,
      "edgeMinComponentArea": 5000,
      "edgePadding": 0,
      "edgeHorizontalPadding": 0,
      "edgeVerticalPadding": 0,
      "panelInnerLeftInset": 0,
      "panelInnerRightInset": 0,
      "panelInnerBottomInset": 48
    }
  },
  "intervalMs": 250,
  "statusEveryMs": 10000,
  "dedupe": {
    "ttlMs": 3600000,
    "maxEntries": 5000,
    "ignoreInitialVisibleLines": true
  },
  "databasePath": "data/pantheon-events.sqlite",
  "debugImagePath": "data/last-capture.png",
  "debugTextPath": "data/last-ocr.txt",
  "debug": {
    "keepCaptureImage": true,
    "keepTimestampedCaptures": false
  },
  "overlay": {
    "enabled": true,
    "writeRegion": true,
    "regionPath": "data/capture-region.json"
  },
  "ocr": {
    "language": "eng",
    "psm": "6",
    "scale": 3,
    "threshold": 135,
    "invert": false,
    "trimBottomNoise": true,
    "textRowMinBlackRatio": 0.012,
    "textRowBuckets": 32,
    "textRowMinBuckets": 6,
    "textMinRunHeight": 8,
    "textBottomPadding": 12,
    "textTrimMinPixels": 16
  }
}
